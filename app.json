{
  "expo": {
    "name": "URL Player+",
    "slug": "url-player",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "urlplayer",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#101010"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.urlplayer.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "URL Player+ needs access to save media to your photo library.",
        "NSPhotoLibraryAddUsageDescription": "URL Player+ needs access to save videos and images to your photo library."
      }
    },
    "android": {
      "package": "com.urlplayer.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#101010"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow URL Player+ to save media to your library.",
          "savePhotosPermission": "Allow URL Player+ to save media to your library.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
